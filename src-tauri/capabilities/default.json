{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability — invoke commands, spawn bundled sing-box sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/sing-box",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
