{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoneyMakers VPN",
  "version": "0.0.8",
  "identifier": "inc.moneymakers.vpn",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MoneyMakers VPN",
        "width": 420,
        "height": 560,
        "resizable": false,
        "minWidth": 380,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/sing-box"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
